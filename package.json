{
  "name": "scp-action",
  "type": "module",
  "main": "dist/index.cjs",
  "version": "0.2.0",
  "scripts": {
    "build": "tsc",
    "start": "tsc -w",
    "package": "npm run build && ncc build lib/index.cjs -o dist",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepare": "npm run package"
  },
  "jest": {
    "clearMocks": true,
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "verbose": true,
    "setupFiles": [
      "dotenv/config"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "glob": "^13.0.6",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.15.5",
    "@vercel/ncc": "^0.38.4",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "lefthook": "^2.1.6",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
